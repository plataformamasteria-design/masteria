# install phase
ENV NIXPACKS_PATH=/app/node_modules/.bin:$NIXPACKS_PATH
COPY . /app/.
RUN --mount=type=cache,id=s/7c8cd7bd-09ff-4383-b665-397c849260f1-/root/npm,target=/root/.npm npm install --no-audit

# build phase
COPY . /app/.
RUN --mount=type=cache,id=s/7c8cd7bd-09ff-4383-b665-397c849260f1-next/cache,target=/app/.next/cache --mount=type=cache,id=s/7c8cd7bd-09ff-4383-b665-397c849260f1-node_modules/cache,target=/app/node_modules/.cache npm run build


RUN printf '\nPATH=/app/node_modules/.bin:$PATH' >> /root/.profile


# start
COPY . /app

CMD ["node scripts/start-railway.js"]

