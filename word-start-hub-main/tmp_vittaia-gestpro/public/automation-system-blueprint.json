  "database_schema": {
    "tables": {
      "automations": {
        "description": "Main automation records",
        "columns": {
          "id": "uuid PK default gen_random_uuid()",
          "name": "text NOT NULL",
          "description": "text NULL",
          "status": "text DEFAULT 'draft' -- draft | active | paused",
          "trigger_type": "text DEFAULT 'stage_entry' -- stage_entry | message_received | tag_added | manual | webhook | scheduled",
          "funnel_id": "uuid NULL FK -> funnels(id)",
          "trigger_stage_id": "uuid NULL FK -> funnel_stages(id)",
          "webhook_token": "text NULL -- unique token for webhook triggers",
          "schedule_config": "jsonb NULL -- { interval: number, unit: 'seconds'|'minutes'|'hours'|'days' }",
          "organization_id": "uuid NOT NULL FK -> organizations(id)",
          "created_by": "uuid NULL FK -> profiles(id)",
          "created_at": "timestamptz DEFAULT now()",
          "updated_at": "timestamptz DEFAULT now()"
        }
      },
      "automation_nodes": {
        "description": "Individual nodes within an automation flow",
        "columns": {
          "id": "uuid PK default gen_random_uuid()",
          "automation_id": "uuid NOT NULL FK -> automations(id)",
          "organization_id": "uuid NOT NULL FK -> organizations(id)",
          "node_type": "text NOT NULL",
          "label": "text NULL -- custom user label",
          "config": "jsonb DEFAULT '{}' -- node-specific configuration",
          "position_x": "numeric DEFAULT 0",
          "position_y": "numeric DEFAULT 0",
          "created_at": "timestamptz DEFAULT now()"
        }
      },
      "automation_edges": {
        "description": "Connections between nodes",
        "columns": {
          "id": "uuid PK default gen_random_uuid()",
          "automation_id": "uuid NOT NULL FK -> automations(id)",
          "organization_id": "uuid NOT NULL FK -> organizations(id)",
          "source_node_id": "uuid NOT NULL FK -> automation_nodes(id)",
          "target_node_id": "uuid NOT NULL FK -> automation_nodes(id)",
          "source_handle_id": "text NULL -- for nodes with multiple outputs (e.g., 'yes', 'no', 'timeout')",
          "condition_label": "text NULL -- display label on the edge",
          "condition_value": "text NULL -- value for conditional routing",
          "created_at": "timestamptz DEFAULT now()"
        }
      },
      "automation_executions": {
        "description": "Track each automation run for a specific chat/lead",
        "columns": {
          "id": "uuid PK default gen_random_uuid()",
          "automation_id": "uuid NOT NULL FK -> automations(id)",
          "organization_id": "uuid NOT NULL FK -> organizations(id)",
          "chat_id": "uuid NOT NULL FK -> chats(id)",
          "status": "text DEFAULT 'running' -- running | completed | failed | waiting | waiting_response | cancelled",
          "current_node_id": "uuid NULL FK -> automation_nodes(id)",
          "context": "jsonb DEFAULT '{}' -- runtime variables and state",
          "resume_at": "timestamptz NULL -- for delay/timeout nodes",
          "started_at": "timestamptz DEFAULT now()",
          "completed_at": "timestamptz NULL",
          "created_at": "timestamptz DEFAULT now()"
        }
      },
      "automation_execution_logs": {
        "description": "Per-node execution log entries",
        "columns": {
          "id": "uuid PK default gen_random_uuid()",
          "execution_id": "uuid NOT NULL FK -> automation_executions(id)",
          "organization_id": "uuid NOT NULL FK -> organizations(id)",
          "node_id": "uuid NOT NULL FK -> automation_nodes(id)",
          "status": "text DEFAULT 'ok' -- ok | error | skipped | waiting",
          "message": "text NULL -- human-readable log message + token usage appended",
          "created_at": "timestamptz DEFAULT now()"
        }
      },
      "automation_node_stats": {
        "description": "Aggregated statistics per node",
        "columns": {
          "id": "uuid PK default gen_random_uuid()",
          "node_id": "uuid NOT NULL UNIQUE FK -> automation_nodes(id)",
          "automation_id": "uuid NOT NULL FK -> automations(id)",
          "organization_id": "uuid NOT NULL FK -> organizations(id)",
          "total_reached": "integer DEFAULT 0",
          "total_responded": "integer DEFAULT 0",
          "responses": "jsonb DEFAULT '{}' -- includes _reached_chats and _responded_chats arrays for dedup",
          "updated_at": "timestamptz DEFAULT now()"
        }
      },
      "ai_agent_credentials": {
        "description": "API keys for AI providers (OpenAI, Gemini)",
        "columns": {
          "id": "uuid PK",
          "name": "text NOT NULL",
          "provider": "text NOT NULL -- openai | gemini",
          "api_key": "text NOT NULL -- encrypted",
          "organization_id": "uuid NOT NULL FK -> organizations(id)",
          "created_at": "timestamptz DEFAULT now()",
          "updated_at": "timestamptz DEFAULT now()"
        }
      },
      "ai_agent_memory": {
        "description": "Conversation memory for AI agents per lead",
        "columns": {
          "id": "uuid PK",
          "organization_id": "uuid NOT NULL FK -> organizations(id)",
          "memory_key": "text NOT NULL -- typically 'phone:orgId' or custom key",
          "messages": "jsonb DEFAULT '[]' -- array of {role, content} messages",
          "created_at": "timestamptz DEFAULT now()",
          "updated_at": "timestamptz DEFAULT now()"
        }
      }
    },
    "database_functions": {
      "increment_node_stat_reached": {
        "description": "Atomically increment reached count with chat_id deduplication",
        "params": ["p_node_id uuid", "p_automation_id uuid", "p_organization_id uuid", "p_chat_id uuid DEFAULT NULL"],
        "type": "SECURITY DEFINER"
      },
      "increment_node_stat_responded": {
        "description": "Atomically increment responded count with chat_id deduplication",
        "params": ["p_node_id uuid", "p_automation_id uuid", "p_organization_id uuid", "p_chat_id uuid DEFAULT NULL"],
        "type": "SECURITY DEFINER"
      }
    },
    "triggers": {
      "notify_automation_on_stage_entry": {
        "description": "Fires when a lead enters a CRM stage, triggers automation-executor edge function",
        "table": "chat_funnel_stage",
        "events": ["INSERT", "UPDATE"],
        "action": "HTTP POST to automation-executor with trigger_type='stage_entry'"
      }
    }
  },

  "edge_functions": {
    "automation-executor": {
      "description": "Main automation engine that processes flow execution node by node",
      "trigger": "Called by database triggers, webhook triggers, or scheduled cron",
      "input": {
        "trigger_type": "string",
        "chat_id": "string",
        "stage_id": "string (optional)",
        "funnel_id": "string (optional)",
        "organization_id": "string",
        "message_content": "string (optional, for message triggers)"
      },
      "behavior": [
        "1. Find matching active automations for the trigger",
        "2. Create an execution record",
        "3. Traverse flow graph starting from trigger node",
        "4. Execute each node based on node_type",
        "5. Handle branching (condition, filter, router, intent)",
        "6. Pause on wait/delay nodes, set resume_at",
        "7. Log each node execution",
        "8. Update execution status on completion/failure"
      ]
    },
    "automation-delay-resume": {
      "description": "Cron job (every minute) that resumes paused executions",
      "trigger": "pg_cron every 1 minute",
      "behavior": "Finds executions with status='waiting_response' and resume_at < now(), then continues flow"
    },
    "automation-webhook-trigger": {
      "description": "HTTP endpoint for webhook-triggered automations",
      "method": "POST",
      "input": "?token=<webhook_token> + JSON body",
      "behavior": "Validates token, finds automation, starts execution with webhook data as context"
    },
    "ai-agent-execute": {
      "description": "Executes AI agent calls (OpenAI/Gemini) with memory and tools",
      "input": {
        "organization_id": "string",
        "credential_id": "string",
        "model": "string",
        "system_message": "string",
        "prompt": "string",
        "tools": "array (optional)",
        "phone": "string",
        "chat_id": "string (optional)",
        "memory_key": "string (optional)",
        "temperature": "number (optional)",
        "max_iterations": "number (optional)"
      },
      "output": {
        "output": "string -- AI generated text",
        "usage": { "prompt_tokens": "number", "completion_tokens": "number", "total_tokens": "number" }
      }
    },
    "send-to-evolution": {
      "description": "Sends WhatsApp messages via Evolution API",
      "input": {
        "organization_id": "string",
        "phone": "string",
        "message": "string",
        "message_type": "text | image | audio | video | document",
        "file_url": "string (optional)",
        "file_name": "string (optional)"
      }
    },
    "http-proxy": {
      "description": "CORS-free HTTP proxy for HTTP Request nodes",
      "input": { "url": "string", "method": "string", "headers": "object", "body": "string" }
    }
  },

