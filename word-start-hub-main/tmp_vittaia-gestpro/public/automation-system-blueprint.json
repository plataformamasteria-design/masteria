  "ui_architecture": {
    "pages": {
      "Automations": {
        "path": "/automations",
        "file": "src/pages/Automations.tsx",
        "description": "Main automation listing page with 3 tabs: Flow, AI Prompt, Auto Messages",
        "tabs": [
          { "value": "fluxo", "label": "Automação por Fluxo", "component": "AutomationList" },
          { "value": "ia", "label": "Automação I.A", "component": "DynamicPromptEditor" },
          { "value": "mensagens", "label": "Mensagens Automáticas", "component": "AutoMessagesSettings" }
        ]
      },
      "AutomationFlowEditor": {
        "path": "/automations/:id",
        "file": "src/pages/AutomationFlowEditor.tsx",
        "description": "Visual flow editor using ReactFlow",
        "layout": {
          "header": "Fixed 56px top bar with back button, name, auto-layout, history, save",
          "canvas": "Full-height ReactFlow canvas with dots background",
          "sidebar_right": "ExecutionHistoryPanel (toggleable)",
          "floating_menu": "NodeToolbar dropdown for adding nodes"
        }
      }
    },

    "components": {
      "AutomationCard": {
        "file": "src/components/automations/AutomationCard.tsx",
        "description": "Card displaying automation name, status badge, trigger type, funnel/stage, execution count, and actions (edit, pause/activate, history, export, delete)"
      },
      "AutomationCreateDialog": {
        "file": "src/components/automations/AutomationCreateDialog.tsx",
        "description": "Dialog for creating/editing automations with name, description, trigger type, funnel/stage selectors, schedule config, webhook URL display"
      },
      "AutomationFlowEditor": {
        "file": "src/components/automations/AutomationFlowEditor.tsx",
        "description": "Main flow editor component (1147 lines). Handles node/edge state, CRUD, save/load, auto-layout, node execution testing, and inline node insertion"
      },
      "NodeToolbar": {
        "file": "src/components/automations/NodeToolbar.tsx",
        "description": "Dropdown menu for adding new nodes, organized by categories with locked sections"
      },
      "NodeHeader": {
        "file": "src/components/automations/nodes/NodeHeader.tsx",
        "description": "Reusable header for all nodes with icon, label, rename (double-click), duplicate, delete, execute buttons. Uses drag-handle-area for restricted dragging"
      },
      "NodeStatsBar": {
        "file": "src/components/automations/nodes/NodeStatsBar.tsx",
        "description": "Bottom bar showing reached/responded counts with conversion rate"
      },
      "NodeOutputPanel": {
        "file": "src/components/automations/nodes/NodeOutputPanel.tsx",
        "description": "Collapsible output panel showing test execution results with JSON schema viewer, drag-to-insert variables, pin/unpin, and test lead selector"
      },
      "VariablePicker": {
        "file": "src/components/automations/VariablePicker.tsx",
        "description": "Popover showing available custom fields as {{variable}} tokens for insertion"
      },
      "DeletableEdge": {
        "file": "src/components/automations/edges/DeletableEdge.tsx",
        "description": "Custom edge with hover-to-show delete button and optional label"
      },
      "ExecutionHistoryPanel": {
        "file": "src/components/automations/ExecutionHistoryPanel.tsx",
        "description": "Side panel showing last 3 executions with timeline, node logs, and token usage breakdown"
      }
    },

    "design_patterns": {
      "node_styling": {
        "container": "bg-card border border-border rounded-xl shadow-lg min-w-[260px] overflow-hidden group",
        "header": "Uses NodeHeader component with color-coded background",
        "body": "px-4 py-3 space-y-2/3",
        "handles": "!w-3 !h-3 !bg-{color}-500 !border-2 !border-background",
        "drag_restriction": "dragHandle: '.drag-handle-area' on node config",
        "overflow": "overflow-visible on nodes with external handles (intent_router, filter, router)"
      },
      "edge_styling": {
        "type": "deletable (custom)",
        "animated": true,
        "stroke": "hsl(var(--primary))",
        "strokeWidth": 2,
        "markerEnd": "ArrowClosed"
      },
      "auto_layout": {
        "library": "@dagrejs/dagre",
        "direction": "TB (top-to-bottom)",
        "nodesep": 80,
        "ranksep": 120,
        "edgesep": 40
      }
    }
  },

  "variable_system": {
    "syntax": "{{variable_name}}",
    "native_variables": ["nome", "telefone", "email", "instagram", "endereco", "cidade", "estado", "cep", "cpf_cnpj", "empresa", "observacoes"],
    "node_output_variables": "{{ NomeDoNó.$json.campo }}",
    "interpolation_regex": "/\\{\\{\\s*([^}]+?)\\s*\\}\\}/g",
    "drag_and_drop": "Variables from NodeOutputPanel can be dragged into text fields"
  },

  "export_import": {
    "format": "vitta-automation-v1",
    "file": "src/lib/automation-export-import.ts",
    "export_structure": {
      "_format": "vitta-automation-v1",
      "name": "string",
      "description": "string",
      "trigger_type": "string",
      "schedule_config": "object",
      "nodes": [{ "temp_id": "string", "node_type": "string", "label": "string", "config": "object", "position_x": "number", "position_y": "number" }],
      "edges": [{ "source_temp_id": "string", "target_temp_id": "string", "source_handle_id": "string", "condition_label": "string", "condition_value": "string" }],
      "exported_at": "ISO date string"
    },
    "import_behavior": "Maps temp_ids to new UUIDs, creates automation + nodes + edges in target organization"
  },

  "execution_engine": {
    "flow_traversal": {
      "algorithm": "BFS from trigger node following edges",
      "state_management": "execution.context stores runtime variables per node output",
      "branching": {
        "condition": "Evaluates condition_type against lead data or last response",
        "filter": "Evaluates all/any conditions, routes to 'pass' or 'block' handle",
        "router": "Evaluates rules sequentially, routes to matching handle or 'fallback'",
        "intent_router": "AI classifies message, normalizes to uppercase, matches handle ID"
      },
      "pausing": {
        "delay": "Sets resume_at = now() + delay amount",
        "wait_response": "Sets status='waiting_response', resumes on inbound message",
        "ai_agent_timeout": "Sets resume_at for timeout, resets on each new message in dialogue mode",
        "follow_up_timeout": "Sets resume_at, routes to 'responded' or 'not_responded'"
      }
    },
    "save_logic": {
      "order": "1. Delete all edges, 2. Delete all nodes, 3. Insert new nodes (with UUID mapping), 4. Insert new edges",
      "id_mapping": "Frontend temporary IDs (e.g., 'send_message-1710000000') are converted to valid UUIDs via crypto.randomUUID()",
      "validation": "isValidUUID regex check before deciding to reuse or generate new ID"
    }
  },

  "ai_integration": {
    "providers": {
      "openai": {
        "models": ["gpt-4o", "gpt-4o-mini", "gpt-4-turbo", "gpt-4.1", "gpt-4.1-mini", "gpt-3.5-turbo"]
      },
      "gemini": {
        "models": ["gemini-2.5-flash", "gemini-2.5-pro", "gemini-2.0-flash", "gemini-1.5-pro", "gemini-1.5-flash"]
      }
    },
    "platform_credits": {
      "vitta-openai": "Platform-managed OpenAI tokens (no user API key needed)",
      "vitta-gemini": "Platform-managed Gemini tokens"
    },
    "message_splitting": {
      "delimiter": "⌁⌁⌁",
      "fallback": "Split by newlines if delimiter not found",
      "behavior": "Each part sent as separate WhatsApp message with configurable delay"
    },
    "humanize_text": {
      "description": "Second AI pass without memory to remove robotic tone and excess emojis",
      "token_accounting": "Both generation and humanization tokens are summed in billing"
    },
    "head_prompt": {
      "description": "Global master instruction (is_head_prompt flag in ai_prompts metadata)",
      "injection": "Prepended to system_message when toggle is active in AI Agent node"
    }
  },

  "testing_system": {
    "description": "Each node can be tested individually from the flow editor",
    "test_lead_selector": "Dropdown to select a real lead for testing (sends actual messages)",
    "node_output_panel": {
      "schema_viewer": "Displays output as draggable JSON schema tree",
      "pin_support": "Pin output panels to keep them visible",
      "error_display": "Red error panel with message"
    },
    "lead_required_nodes": ["send_message", "send_image", "send_audio", "send_document", "send_video", "send_ai_response", "ask_question", "wait_response", "capture_info", "follow_up_ai"]
  }
}
