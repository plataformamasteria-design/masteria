# Ignore these files/directories during Replit deployment
# This helps reduce the deployment image size below 8 GiB limit

# === Git ===
.git
.gitignore
.gitattributes

# === Build caches ===
node_modules/.cache
.next/cache
.cache

# === Session data (runtime-only, handled by external storage) ===
whatsapp_sessions

# === Test artifacts ===
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
__tests__/
tests
testsprite_tests
coverage

# === Logs ===
logs
*.log
npm-debug.log*
yarn-debug.log*
debug-*.log

# === Documentation (not needed at runtime) ===
docs
*.md
!README.md

# === IDE and editor ===
.vscode
.idea
*.swp
*.swo

