modules = ["nodejs-20", "bash", "web", "nix", "postgresql-16"]

[agent]
expertMode = true
mockupState = "FULLSTACK"
integrations = ["javascript_object_storage:1.0.0", "replitmail:1.0.0"]

[nix]
channel = "stable-25_05"
packages = [
    "ffmpeg-full",
    "postgresql_17",
    "imagemagick",
    "poppler",
    "procps",
    "psmisc",
    "chromium",
    "glib",
    "nss",
    "nspr",
    "atk",
    "cups",
    "pango",
    "cairo",
    "gtk3",
    "alsa-lib",
    "expat",
    "at-spi2-atk",
    "dbus",
    "mesa",
    "xorg.libXcomposite",
    "xorg.libXdamage",
    "xorg.libXrandr",
    "xorg.libxcb",
    "xorg.libX11"
]

[env]
DISPLAY = ":1"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Development Server"

[[workflows.workflow]]
name = "Development Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[deployment]
deploymentTarget = "gce"
run = ["npm", "run", "start:prod"]
build = ["sh", "-c", "rm -rf .next && SKIP_LINT=true SKIP_TYPECHECK=true NEXT_TELEMETRY_DISABLED=1 next build"]
healthCheckPath = "/health"

[objectStorage]
defaultBucketID = "replit-objstore-5c7db24d-3f1a-48f3-a419-34323e1b5779"

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[userenv]

[userenv.shared]
DB_DEBUG = "true"
# UPSTASH_REDIS_REST_URL - Set in Replit Secrets
ENABLE_BULLMQ_QUEUE = "true"
VOICE_AI_PLATFORM_URL = "https://plataformai.global"
TWILIO_PHONE_NUMBER = "+553322980007"
TWILIO_SIP_TERMINATION_URI = "retell-1765080490561.pstn.twilio.com"
NEXT_PUBLIC_APP_URL = "https://62863c59-d08b-44f5-a414-d7529041de1a-00-16zuyl87dp7m9.kirk.replit.dev"
NEXT_PUBLIC_CUSTOM_DOMAIN = "masteria.app"
DEBUG = "false"
# REDIS_URL - Set in Replit Secrets
# UPSTASH_REDIS_REST_TOKEN - Set in Replit Secrets

[userenv.production]
NEXTAUTH_URL = "https://masteria.app"
NODE_ENV = "production"
BAILEYS_SESSIONS_ENABLED = "true"

[userenv.development]
NEXTAUTH_URL = "https://62863c59-d08b-44f5-a414-d7529041de1a-00-16zuyl87dp7m9.kirk.replit.dev"
BAILEYS_SESSIONS_ENABLED = "true"
