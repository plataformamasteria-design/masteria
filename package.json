{
  "name": "nextn",
  "version": "3.0.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.2.4",
  "scripts": {
    "dev": "next dev -p 3000 --hostname 0.0.0.0",
    "dev:server": "NODE_OPTIONS='--max-old-space-size=2048 --expose-gc' tsx watch src/server.ts",
    "dev:safe": "node scripts/auto-fix-server.js && npm run dev:server",
    "dev:clean": "set NODE_OPTIONS=--no-deprecation && next dev -p 3000 --hostname 0.0.0.0",
    "dev:lite": "next dev --turbo -p 3000",
    "dev:server:lite": "tsx watch src/server.ts",
    "build": "SKIP_LINT=true SKIP_TYPECHECK=true SKIP_REDIS_CHECK=true next build",
    "build:fast": "next build",
    "build:replit": "node scripts/portal-clean.js .next && next build",
    "build:prod": "next build",
    "start": "node --max-old-space-size=2048 --expose-gc src/server.js",
    "start:prod": "node --max-old-space-size=2048 --expose-gc src/server.js",
    "sync": "git config pull.rebase false && git pull origin main && git push origin main",
    "replit:fix": "git fetch origin && git reset --hard origin/main",
    "lint": "eslint . --ext .ts,.tsx --cache --cache-location .next/cache/eslint",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "fix": "bash scripts/auto-fix-server.sh",
    "fix:restart": "bash scripts/auto-fix-server.sh && npm run dev:server",
    "health": "bash scripts/health-check.sh",
    "db:generate": "drizzle-kit generate",
    "db:generate:vector": "drizzle-kit generate --config=drizzle.vector.config.ts",
    "db:migrate": "node --env-file=.env.local --env-file=.env node_modules/tsx/dist/cli.mjs scripts/migrate-db.ts",
    "db:migrate:vector": "tsx scripts/migrate-vector-db.ts",
    "db:push": "yes '' | drizzle-kit push --config=drizzle.config.ts",
    "db:rollback": "tsx scripts/rollback-db.ts",
    "db:reset": "rm -rf drizzle && npm run db:generate && npm run db:migrate",
    "db:seed": "tsx scripts/seed-db.ts",
    "test:queue": "tsx scripts/seed-test-campaigns.ts",
    "seed:templates": "tsx src/scripts/seed-predefined-templates.ts",
    "lint:fix": "eslint . --ext .ts,.tsx --fix --fix-type problem,suggestion,layout"
  },
